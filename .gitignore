# =============================================================
# PROJECT 87 - Whitelist-based .gitignore
# Ignore EVERYTHING, then selectively un-ignore essential files
# =============================================================

# Step 1: Ignore everything
*

# Step 2: Allow directories to be traversed
!*/

# Step 3: Whitelist essential Python modules
!run_both.py
!run_autonomous_mainnet.py
!web_dashboard.py
!strategy_engine.py
!delegation_client.py
!db.py
!config.py
!config_constants.py
!constants.py
!permissions.py
!aave_integration.py
!aave_health_monitor.py
!uniswap_integration.py
!gas_fee_calculator.py
!block_event_monitor.py
!arbitrum_testnet_agent.py
!auto_supply.py
!pnl_converter.py
!enhanced_market_analyzer.py
!enhanced_debt_position_detector.py
!market_signal_strategy.py
!perplexity_client.py
!searchiqs_scraper.py
!google_client.py
!real_estate_tasks.py
!hard_reset_user.py
!api_server.py
!delegation_sig_processor.py

# Step 4: Whitelist templates
!templates/
!templates/**

# Step 5: Whitelist static assets
!static/
!static/**

# Step 6: Whitelist contracts and ABIs
!contracts/
!contracts/**
!abi_cache/
!abi_cache/**

# Step 7: Whitelist scripts
!scripts/
!scripts/**

# Step 8: Whitelist config/meta files
!.gitignore
!.replit
!replit.md
!requirements.txt
!pyproject.toml

# Step 9: Always exclude these even if whitelisted above
__pycache__/
*.py[cod]
*$py.class
*.so
*.bin
*.mat
*.gz
*.log
.env
.venv
*.egg-info/
