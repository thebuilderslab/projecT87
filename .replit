[[workflows.workflow]]
name = "🚀 LAUNCH MAINNET"
author = 39391053
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python mainnet_launcher.py"

[[ports]]
localPort = 5000
externalPort = 80
