entrypoint = "main.py"
modules = ["python-3.11"]

[nix]
channel = "stable-24_05"

[unitTest]
language = "python3"

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[deployment]
run = ["sh", "-c", "python mainnet_launcher.py"]
deploymentTarget = "cloudrun"

[workflows]
runButton = "🚀 LAUNCH MAINNET"

[[workflows.workflow]]
name = "Run"
author = 39391053
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"

[[workflows.workflow]]
name = "Web Dashboard"
author = 39391053
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python mainnet_launcher.py"

[[workflows.workflow]]
name = "Mainnet Launcher"
author = 39391053
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python mainnet_launcher.py"

[[workflows.workflow]]
