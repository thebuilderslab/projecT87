entrypoint = "main.py"
modules = ["python-3.11"]

[nix]
channel = "stable-25_05"
packages = ["glibcLocales"]

[unitTest]
language = "python3"

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[run]
run = "python web_dashboard.py"

[deployment]
run = ["sh", "-c", "python web_dashboard.py"]
deploymentTarget = "cloudrun"

[workflows]
runButton = "🔍 System Validation"

[[workflows.workflow]]
name = "🔍 Test Enhanced Diagnostics Fixed"
author = 39391053
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"🔍 Testing Enhanced Diagnostics with All Fixes Applied\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"==================================================\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python test_all_fixes.py"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"🔍 Testing Wallet Diagnostics\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"==============================\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python wallet_diagnostics.py"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"🔍 Testing Readiness Verification\"  "

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"==================================\""

[[workflows.workflow.tasks]]
