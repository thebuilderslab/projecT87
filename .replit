entrypoint = "main.py"
modules = ["python-3.11"]

[nix]
channel = "stable-24_05"
packages = ["glibcLocales"]

[unitTest]
language = "python3"

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[run]
run = "python web_dashboard.py"

[deployment]
run = ["sh", "-c", "python web_dashboard.py"]
deploymentTarget = "gce"

[workflows]
runButton = "Project"

