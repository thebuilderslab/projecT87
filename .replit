args = "python test_real_agent.py"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"🔍 All Enhanced Diagnostics Complete\""

[[workflows.workflow]]
name = "🤖 Hybrid Autonomous System"
author = 39391053
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"

[[workflows.workflow]]
name = "🌐 Dashboard with Mode Selection"
author = 39391053
mode = "sequential"

[[workflows.workflow.tasks]]
