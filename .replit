args = "    from web_dashboard import get_enhanced_aave_data"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    aave_data = get_enhanced_aave_data(agent)"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    if aave_data:"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "        print(f'✅ Aave data retrieved successfully')"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = '''        print(f'   Health Factor: {aave_data[\"health_factor\"]}')'''

[[workflows.workflow.tasks]]
task = "shell.exec"
args = '''        print(f'   Collateral: ${aave_data[\"total_collateral_usdc\"]:,.2f}')'''

[[workflows.workflow.tasks]]
task = "shell.exec"
args = '''        print(f'   Debt: ${aave_data[\"total_debt_usdc\"]:,.2f}')'''

[[workflows.workflow.tasks]]
