entrypoint = "main.py"
modules = ["python-3.11"]

[nix]
channel = "stable-24_05"
packages = ["glibcLocales"]

[unitTest]
language = "python3"

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[deployment]
run = ["sh", "-c", "python mainnet_launcher.py"]
deploymentTarget = "cloudrun"

[workflows]
runButton = "🔍 COMPREHENSIVE SYSTEM TEST"

