entrypoint = "main.py"
modules = ["python-3.11"]

[nix]
channel = "stable-24_05"
packages = ["glibcLocales"]

[unitTest]
language = "python3"

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[run]
run = "python web_dashboard.py"

[deployment]
run = ["sh", "-c", "python run_both.py"]
deploymentTarget = "gce"

[workflows]
runButton = "bot"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Dashboard"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Autonomous Agent"

[[workflows.workflow]]
name = "Dashboard"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python web_dashboard.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Autonomous Agent"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python run_autonomous_mainnet.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "bot"
mode = "sequential"
author = 39391053

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python run_both.py"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5002
externalPort = 3001

[[ports]]
localPort = 5003
externalPort = 3002

[[ports]]
localPort = 5004
externalPort = 3003

[[ports]]
localPort = 5005
externalPort = 4200

[[ports]]
localPort = 5006
externalPort = 5000

[[ports]]
localPort = 5007
externalPort = 5173

[agent]
expertMode = true
integrations = ["perplexity_v0:1.0.0"]
