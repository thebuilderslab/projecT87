entrypoint = "main.py"
modules = ["python-3.11"]

[nix]
channel = "stable-24_05"
packages = ["glibcLocales"]

[unitTest]
language = "python3"

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[deployment]
run = ["sh", "-c", "python mainnet_launcher.py"]
deploymentTarget = "cloudrun"

[workflows]
runButton = "🔍 Test Enhanced Diagnostics Fixed"

[[workflows.workflow]]
name = "🔍 Test Enhanced Diagnostics Fixed"
author = 39391053
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"🔍 Testing Enhanced Diagnostics with All Fixes Applied\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"==================================================\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python test_all_fixes.py"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"🔍 Testing Wallet Diagnostics\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"==============================\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python wallet_diagnostics.py"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"🔍 Testing Readiness Verification\"  "

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"==================================\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python verify_readiness.py"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"🔍 Testing Real Agent Initialization\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"====================================\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python test_real_agent.py"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"🔍 All Enhanced Diagnostics Complete\""

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5002
externalPort = 3001

[[ports]]
localPort = 5003
externalPort = 3002

[[ports]]
localPort = 5004
externalPort = 3003
