entrypoint = "main.py"
modules = ["python-3.11"]
run = "python web_dashboard.py"

[nix]
channel = "stable-25_05"
packages = ["chromium", "glibcLocales", "libxcrypt"]

[unitTest]
language = "python3"

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[deployment]
run = ["sh", "-c", "python run_both.py"]
deploymentTarget = "vm"

# ... workflows unchanged ...

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true
integrations = ["perplexity_v0:1.0.0"]
