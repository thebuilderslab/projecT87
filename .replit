args = "python verify_readiness.py"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"🔍 Testing Real Agent Initialization\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"====================================\""

[[workflows.workflow.tasks]]
