        self._sites.append(site)

        if site not in self._sites:
            raise RuntimeError(f"Site {site} is not registered in runner {self}")

        if site not in self._sites:
            raise RuntimeError(f"Site {site} is not registered in runner {self}")
        self._sites.remove(site)

        return self._app
