    for func, theta in regimes:
        rg, thetag = np.meshgrid(r, theta)
        a, x = rg*np.cos(thetag), rg*np.sin(thetag)
        a, x = a.flatten(), x.flatten()
        dataset = 
        for i, (a0, x0) in enumerate(zip(a, x)):
            if func == gammaincc:
